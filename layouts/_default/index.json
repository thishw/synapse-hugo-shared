{{- $posts := slice -}}
{{- range where site.RegularPages "Section" "posts" -}}
  {{- $posts = $posts | append (dict
        "title" .Title
        "url" .RelPermalink
        "date" (.Date.Format "2006-01-02")
        "content" (.Plain | truncate 5000)
      ) -}}
{{- end -}}
{{- $posts | jsonify -}}
